@model IReadOnlyList<ArtAuctionLive.ViewModels.AuctionListItemViewModel>
@{
    ViewData["Title"] = "Auctions";
}

<h1 class="mb-4">Live Auctions</h1>
<a asp-action="Create" class="btn btn-success mb-4">+ Create auction</a>
<div class="row row-cols-1 row-cols-md-3 g-4">
@foreach (var auction in Model)
{
    <div class="col">
        <div class="card h-100">
            @if (!string.IsNullOrEmpty(auction.ImageUrl))
            {
                <img src="@auction.ImageUrl" class="card-img-top painting-img" onerror="this.style.visibility='hidden'" alt="@auction.PaintingTitle"
                     style="height:200px;object-fit:cover;">
            }
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">@auction.PaintingTitle</h5>
                <h6 class="card-subtitle mb-2 text-muted">@auction.Artist</h6>
                <p class="mb-1">Current price: <strong>@auction.CurrentPrice.ToString("0.00") €</strong></p>
                <p class="mb-3">
                    Status:
                    <span class="badge @(auction.Status == ArtAuctionLive.Models.Entities.AuctionStatus.Running ? "bg-success" : "bg-secondary")">
                        @auction.Status
                    </span>
                </p>
                <a asp-action="Room" asp-route-id="@auction.Id" class="btn btn-primary mt-auto">
                    View auction
                </a>
            </div>
        </div>
    </div>
}
</div>

@if (Model.Count == 0)
{
    <p class="text-muted">No auctions available.</p>
}
